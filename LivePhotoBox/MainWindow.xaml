<Window
    x:Class="LivePhotoBox.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Live Photo Box">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8B9;" FontSize="14" />
                <TextBlock x:Uid="MainWindow_Title" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>

        <NavigationView Grid.Row="1" x:Name="NavView" 
                        PaneDisplayMode="Left" 
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        OpenPaneLength="200" 
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="Nav_Home" Tag="Home" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="Nav_Combo" Tag="Combo">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Icon="Cut" x:Uid="Nav_Split" Tag="Split"/>
                <NavigationViewItem Icon="Repair" x:Uid="Nav_Repair" Tag="Repair"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="Console" x:Uid="Nav_Console">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE756;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="About" x:Uid="Nav_About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Frame x:Name="MainFrame" Grid.Row="0" Padding="24" Background="Transparent"/>

                <Border x:Name="PageStatusBar"
                        Grid.Row="1"
                        Visibility="Collapsed"
                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Height="32">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind ViewModel.CurrentPageStatus, Mode=OneWay}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Opacity="0.8"/>

                        <HyperlinkButton Grid.Column="1"
                                         NavigateUri="https://github.com/LengxiQwQ"
                                         VerticalAlignment="Center"
                                         Opacity="0.5"
                                         Padding="4,2"
                                         Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                            <HyperlinkButton.Content>
                                <TextBlock x:Uid="MainWindow_Footer" FontSize="11" />
                            </HyperlinkButton.Content>
                        </HyperlinkButton>
                    </Grid>
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Window>