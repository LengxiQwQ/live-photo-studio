<Page
    x:Class="LivePhotoBox.Views.SettingsPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Background="Transparent"
    NavigationCacheMode="Required">

    <ScrollViewer x:Name="PageScrollViewer" Padding="40,24,40,0" HorizontalContentAlignment="Center">

        <Grid HorizontalAlignment="Stretch">

            <StackPanel x:Name="ContentPanel" Spacing="24" MaxWidth="1100" HorizontalAlignment="Stretch" Margin="0,0,0,40">

                <TextBlock x:Uid="SettingsPage_Title" FontSize="32" FontWeight="Bold" Margin="0,0,0,8" FontFamily="Microsoft YaHei UI"/>

                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE790;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock x:Uid="SettingsPage_Appearance_Header" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                    </StackPanel>

                    <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                            Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <Grid x:Name="AppearanceOptionsGrid" ColumnSpacing="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="8">
                                <ComboBox x:Uid="SettingsPage_Language" HorizontalAlignment="Stretch" 
                                          SelectedIndex="{x:Bind ViewModel.LanguageIndex, Mode=TwoWay}">
                                    <ComboBoxItem x:Uid="SettingsPage_Language_System"/>
                                    <ComboBoxItem x:Uid="SettingsPage_Language_Chinese"/>
                                    <ComboBoxItem x:Uid="SettingsPage_Language_English"/>
                                </ComboBox>
                                <TextBlock x:Uid="SettingsPage_Language_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <ComboBox x:Uid="SettingsPage_Backdrop_Header" HorizontalAlignment="Stretch" 
                                          SelectedIndex="{x:Bind ViewModel.BackdropIndex, Mode=TwoWay}">
                                    <ComboBoxItem x:Uid="SettingsPage_Backdrop_Mica"/>
                                    <ComboBoxItem x:Uid="SettingsPage_Backdrop_MicaAlt"/>
                                    <ComboBoxItem x:Uid="SettingsPage_Backdrop_Acrylic"/>
                                    <ComboBoxItem x:Uid="SettingsPage_Backdrop_None"/>
                                </ComboBox>
                                <TextBlock x:Uid="SettingsPage_Backdrop_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="8">
                                <ComboBox x:Uid="SettingsPage_Theme_Header" HorizontalAlignment="Stretch" 
                                          SelectedIndex="{x:Bind ViewModel.ElementTheme, Mode=TwoWay}">
                                    <ComboBoxItem x:Uid="SettingsPage_Theme_System"/>
                                    <ComboBoxItem x:Uid="SettingsPage_Theme_Light"/>
                                    <ComboBoxItem x:Uid="SettingsPage_Theme_Dark"/>
                                </ComboBox>
                                <TextBlock x:Uid="SettingsPage_Theme_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE7BA;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock x:Uid="SettingsPage_Crash_Header" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                    </StackPanel>

                    <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}"
                            Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock x:Uid="SettingsPage_CrashLastTime_Label" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <HyperlinkButton Command="{x:Bind ViewModel.OpenLatestCrashLogActionCommand}" Padding="0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.LastCrashFileNameText, Mode=OneWay}" TextWrapping="Wrap" FontSize="15" FontWeight="SemiBold"/>
                                </HyperlinkButton>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Command="{x:Bind ViewModel.OpenCrashLogFolderActionCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE838;" FontSize="14"/>
                                        <TextBlock x:Uid="SettingsPage_CrashOpenFolder_Button_Text" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{x:Bind ViewModel.ExportLatestCrashLogActionCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                        <TextBlock x:Uid="SettingsPage_CrashExportLatest_Button_Text" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{x:Bind ViewModel.ClearCrashLogsActionCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                        <TextBlock x:Uid="SettingsPage_CrashClear_Button_Text" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{x:Bind ViewModel.OpenIssueFeedbackActionCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                                        <TextBlock x:Uid="SettingsPage_CrashIssue_Button_Text" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,20,0,0" Spacing="24">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                HorizontalAlignment="Left"
                                Click="ToggleTestToolsButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xEBE8;" FontSize="14"/>
                                <TextBlock Text="{x:Bind TestToolsToggleButtonText, Mode=OneWay}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1"
                                Command="{x:Bind ViewModel.RestoreDefaultSettingsCommand}"
                                HorizontalAlignment="Right"
                                Style="{ThemeResource DefaultButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock x:Uid="SettingsPage_Restore_Button_Text" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <StackPanel Spacing="16"
                                Visibility="{x:Bind TestToolsVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xEC7A;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                            <TextBlock x:Uid="SettingsPage_Test_Header" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                        </StackPanel>

                        <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}"
                                Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Click="GenerateTestCrashLogButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE9D2;" FontSize="14"/>
                                        <TextBlock x:Uid="SettingsPage_CrashGenerateTest_Button_Text" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Click="PreviewCrashDialogButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE8A1;" FontSize="14"/>
                                        <TextBlock x:Uid="SettingsPage_CrashPreviewDialog_Button_Text" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock x:Uid="SettingsPage_Footer"
                               HorizontalAlignment="Center"
                               Opacity="0.55"
                               FontSize="12"
                               FontFamily="Microsoft YaHei UI"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>