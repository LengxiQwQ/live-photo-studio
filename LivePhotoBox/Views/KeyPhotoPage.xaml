<Page
    x:Class="LivePhotoBox.Views.KeyPhotoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    NavigationCacheMode="Required">

    <Grid Padding="24,24,24,0">
        <Border MaxWidth="720"
                Padding="32"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="12">
                <FontIcon Glyph="&#xE895;" FontSize="28" HorizontalAlignment="Center"/>
                <TextBlock x:Uid="KeyPhotoPage_PlaceholderTitle"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Uid="KeyPhotoPage_PlaceholderDescription"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>