<Page
    x:Class="LivePhotoBox.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Background="Transparent"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="40,24,40,0">
        <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Center" Margin="0,0,0,40">

            <Grid x:Name="BannerRoot" Height="350" Margin="0,8,0,8" CornerRadius="12">
                <Image x:Name="BannerImage"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       CacheMode="BitmapCache" />
                <!--<Border CornerRadius="12" Background="#22000000"/>-->
                <!--<Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,-24,0,0">
                    <TextBlock x:Name="HeroTitleShadow"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="#44000000"
                               FontFamily="Microsoft YaHei UI"
                               CharacterSpacing="80"
                               Margin="2,3,0,0"/>
                    <TextBlock x:Name="HeroTitleText"
                               x:Uid="HomePage_HeroTitle"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"
                               FontFamily="Microsoft YaHei UI"
                               CharacterSpacing="80"/>
                </Grid>-->
            </Grid>

            <TextBlock x:Uid="HomePage_HeroSubtitle"
                       FontSize="16" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontFamily="Microsoft YaHei UI"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontWeight="Light"
                       Margin="0,0,0,8"/>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="32" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <StackPanel Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE916;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock x:Uid="HomePage_WelcomeTitle" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                    </StackPanel>
                    <TextBlock x:Uid="HomePage_Intro1" TextWrapping="Wrap" LineHeight="26" FontFamily="Microsoft YaHei UI" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Uid="HomePage_Intro2" TextWrapping="Wrap" LineHeight="26" FontFamily="Microsoft YaHei UI" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!--<TextBlock x:Uid="HomePage_Intro3" TextWrapping="Wrap" LineHeight="26" FontFamily="Microsoft YaHei UI" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>-->
                </StackPanel>
            </Border>

            <TextBlock x:Uid="HomePage_CoreFeaturesTitle" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI" Margin="0,16,0,-8"/>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8B1;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" Margin="0,2,20,0"/>
                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock x:Uid="HomePage_MergeTitle" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI" Margin="0,0,0,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="HomePage_FeatureIntroLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Uid="HomePage_MergeDesc" Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="HomePage_HowToUseLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Uid="HomePage_MergeUsage" Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8C6;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" Margin="0,2,20,0"/>
                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock x:Uid="HomePage_SplitTitle" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI" Margin="0,0,0,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="HomePage_FeatureIntroLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Uid="HomePage_SplitDesc" Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="HomePage_HowToUseLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Uid="HomePage_SplitUsage" Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE7C5;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" Margin="0,2,20,0"/>
                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock x:Uid="HomePage_RepairTitle" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI" Margin="0,0,0,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="HomePage_FeatureIntroLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Uid="HomePage_RepairDesc" Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="HomePage_HowToUseLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Uid="HomePage_RepairUsage" Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
        Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE895;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" Margin="0,2,20,0"/>
                    <StackPanel Grid.Column="1" Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock x:Uid="HomePage_KeyPhotoTitle" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                            <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock x:Uid="HomePage_WIPLabel" FontSize="12" Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="HomePage_FeatureIntroLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Uid="HomePage_KeyPhotoDesc" Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="HomePage_HowToUseLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock x:Uid="HomePage_KeyPhotoUsage" Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" LineHeight="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="HomePage_TipLabel" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top"/>
                    <TextBlock x:Uid="HomePage_TipText"
                               Grid.Column="1"
                               Margin="8,0,0,0"
                               VerticalAlignment="Top"
                               TextWrapping="Wrap"
                               LineHeight="22"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>