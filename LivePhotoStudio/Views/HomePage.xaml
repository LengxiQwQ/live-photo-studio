<Page
    x:Class="LivePhotoStudio.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Background="Transparent"
    NavigationCacheMode="Required">
    <ScrollViewer Padding="40,0,40,24">
        <StackPanel Spacing="24" MaxWidth="1000" HorizontalAlignment="Center">

            <Grid Height="350" Margin="0,32,0,16" CornerRadius="12">

                <Image x:Name="BannerImage" Stretch="UniformToFill" CacheMode="BitmapCache" />

                <Border CornerRadius="12" Background="#40000000"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock x:Uid="HomePage_HeroTitle"
                               FontSize="56" 
                               FontWeight="Bold" 
                               Foreground="#FFFFFF"
                               FontFamily="Microsoft YaHei UI"
                               HorizontalAlignment="Center"
                               CharacterSpacing="80">
                        <TextBlock.Shadow>
                            <ThemeShadow />
                        </TextBlock.Shadow>
                    </TextBlock>

                    <TextBlock x:Uid="HomePage_HeroSubtitle"
                               FontSize="16" 
                               Foreground="#CCFFFFFF"
                               Opacity="0.8"
                               FontFamily="Microsoft YaHei UI"
                               HorizontalAlignment="Center"
                               FontWeight="Light"/>
                </StackPanel>
            </Grid>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="32" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <StackPanel Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE916;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock x:Uid="HomePage_WelcomeTitle" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                    </StackPanel>

                    <TextBlock x:Uid="HomePage_Intro1" TextWrapping="Wrap" LineHeight="26" FontFamily="Microsoft YaHei UI" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <TextBlock x:Uid="HomePage_Intro2" TextWrapping="Wrap" LineHeight="26" FontFamily="Microsoft YaHei UI" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <MenuFlyoutSeparator Margin="-32,0"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE951;" FontSize="16" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Uid="HomePage_TipLabel" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Uid="HomePage_TipText"
                                   Grid.Column="1"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>