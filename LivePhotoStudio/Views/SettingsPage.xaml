<Page
    x:Class="LivePhotoStudio.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Background="Transparent" Language="zh-CN"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="40,24">
        <StackPanel Spacing="32" MaxWidth="1100" HorizontalAlignment="Stretch">
            <TextBlock x:Uid="SettingsPage_Title" FontSize="32" FontWeight="Bold" Margin="0,0,0,8" FontFamily="Microsoft YaHei UI"/>

            <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE790;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock x:Uid="SettingsPage_Appearance_Header" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                </StackPanel>

                <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                        Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid ColumnSpacing="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <ComboBox Header="Language" HorizontalAlignment="Stretch" 
                                      SelectedIndex="{x:Bind ViewModel.LanguageIndex, Mode=TwoWay}">
                                <ComboBoxItem x:Uid="SettingsPage_Language_System" />
                                <ComboBoxItem Content="中文 (简体)"/>
                                <ComboBoxItem Content="English"/>
                            </ComboBox>
                            <TextBlock x:Uid="SettingsPage_Language_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <ComboBox x:Uid="SettingsPage_Backdrop_Header" HorizontalAlignment="Stretch" 
                                      SelectedIndex="{x:Bind ViewModel.BackdropIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Mica"/>
                                <ComboBoxItem Content="Mica Alt"/>
                                <ComboBoxItem Content="Desktop Acrylic"/>
                                <ComboBoxItem x:Uid="SettingsPage_Backdrop_None" />
                            </ComboBox>
                            <TextBlock x:Uid="SettingsPage_Backdrop_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="8">
                            <ComboBox x:Uid="SettingsPage_Theme_Header" HorizontalAlignment="Stretch" 
                                      SelectedIndex="{x:Bind ViewModel.ElementTheme, Mode=TwoWay}">
                                <ComboBoxItem x:Uid="SettingsPage_Theme_System" />
                                <ComboBoxItem x:Uid="SettingsPage_Theme_Light" />
                                <ComboBoxItem x:Uid="SettingsPage_Theme_Dark" />
                            </ComboBox>
                            <TextBlock x:Uid="SettingsPage_Theme_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8B5;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock x:Uid="SettingsPage_Combo_Header" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                </StackPanel>

                <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                        Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid ColumnSpacing="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <ComboBox x:Uid="SettingsPage_Protocol_Header" HorizontalAlignment="Stretch"
                                      SelectedIndex="{x:Bind ViewModel.SelectedModeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Google Micro Video (V1)"/>
                                <ComboBoxItem Content="Google Motion Photo (V2)"/>
                            </ComboBox>
                            <TextBlock x:Uid="SettingsPage_Protocol_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <ComboBox x:Uid="SettingsPage_Threads_Header" HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.ThreadOptions}"
                                      SelectedItem="{x:Bind ViewModel.ThreadCount, Mode=TwoWay}" />
                            <TextBlock FontSize="12" FontFamily="Microsoft YaHei UI" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run x:Uid="SettingsPage_Threads_Desc1" />
                                <LineBreak/>
                                <Run x:Uid="SettingsPage_Threads_Desc2" />
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="10" VerticalAlignment="Top">
                            <ToggleSwitch x:Uid="SettingsPage_Keep_Header" IsOn="{x:Bind ViewModel.KeepOriginal, Mode=TwoWay}" Margin="0,-4,0,0"/>
                            <TextBlock x:Uid="SettingsPage_Keep_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,-8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8C6;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock x:Uid="SettingsPage_Split_Header" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                </StackPanel>

                <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                        Padding="24" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid ColumnSpacing="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <ComboBox x:Uid="SettingsPage_SplitFormat_Header" HorizontalAlignment="Stretch" 
                                      SelectedIndex="{x:Bind ViewModel.SplitVideoFormat, Mode=TwoWay}">
                                <ComboBoxItem Content="MP4 (H.264/HEVC)"/>
                                <ComboBoxItem Content="MOV (QuickTime)"/>
                            </ComboBox>
                            <TextBlock x:Uid="SettingsPage_SplitFormat_Desc" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,20,0,0" Spacing="24">
                <Button x:Uid="SettingsPage_Restore_Button" Command="{x:Bind ViewModel.RestoreDefaultSettingsCommand}" 
                        HorizontalAlignment="Right" Style="{ThemeResource DefaultButtonStyle}"/>

                <HyperlinkButton NavigateUri="https://github.com/LengxiQwQ" HorizontalAlignment="Center" Opacity="0.5"
                                 Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                    <HyperlinkButton.Content>
                        <TextBlock Text="Live Photo Studio v1.1.0  | Powered by LengxiQwQ" FontSize="12" FontFamily="Microsoft YaHei UI"/>
                    </HyperlinkButton.Content>
                </HyperlinkButton>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>