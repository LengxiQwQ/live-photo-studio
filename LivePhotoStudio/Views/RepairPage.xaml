<Page
    x:Class="LivePhotoStudio.Views.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:LivePhotoStudio.Models"
    mc:Ignorable="d" Background="Transparent"
    NavigationCacheMode="Required">

    <Grid Padding="12,0,0,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
            <Rectangle StrokeDashArray="4,4" Stroke="{ThemeResource CyberPurpleBrush}" StrokeThickness="2" RadiusX="8" RadiusY="8" Fill="{ThemeResource CardBackgroundBrush}"/>
            <Image x:Name="BgImage" Opacity="0.1" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8B5;" FontSize="32" Foreground="{ThemeResource CyberCyanBrush}"/>
                <TextBlock x:Uid="RepairPage_DropHint" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Button x:Uid="RepairPage_StartButton" Style="{StaticResource AccentButtonStyle}" Width="120" Height="36" HorizontalAlignment="Right"/>
        </Grid>

        <Border Grid.Row="2" CornerRadius="8" Background="{ThemeResource CardBackgroundBrush}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Padding="8,0,8,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="RepairPage_ColSource" Grid.Column="0" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Uid="RepairPage_ColStatus" Grid.Column="1" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Uid="RepairPage_ColProgress" Grid.Column="2" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Uid="RepairPage_ColDetails" Grid.Column="3" FontWeight="SemiBold" FontSize="13"/>
                </Grid>
                <ListView Grid.Row="1" ItemsSource="{x:Bind RepairTasks}" SelectionMode="None">
                    <ListView.ItemTemplate>
                         <DataTemplate x:DataType="models:LivePhotoTask">
                            <Grid Padding="0,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind FileName}" VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Status, Mode=OneWay}" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <ProgressBar Grid.Column="2" Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind Details, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="13"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>