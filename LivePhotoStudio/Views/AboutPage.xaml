<Page
    x:Class="LivePhotoStudio.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Background="Transparent"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="40,24">
        <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Center">

            <Border Width="120" Height="120" Margin="0,20,0,10" CornerRadius="12" HorizontalAlignment="Center">
                <Image Source="/Assets/StoreLogo.png" Stretch="UniformToFill"/>
            </Border>

            <TextBlock x:Uid="AboutPage_Title" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Microsoft YaHei UI"/>
            <TextBlock x:Uid="AboutPage_Version" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,-16,0,0"/>

            <Border CornerRadius="12" Background="{ThemeResource CardBackgroundBrush}" 
                    Padding="32" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,20,0,0">
                <StackPanel Spacing="16">
                    <TextBlock x:Uid="AboutPage_Header" FontSize="18" FontWeight="SemiBold" FontFamily="Microsoft YaHei UI"/>
                    <TextBlock x:Uid="AboutPage_Description" TextWrapping="Wrap" LineHeight="24" FontFamily="Microsoft YaHei UI" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <MenuFlyoutSeparator Margin="0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="AboutPage_DeveloperLabel" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        <HyperlinkButton Grid.Column="1" NavigateUri="https://github.com/LengxiQwQ" Content="LengxiQwQ (冷汐OωO)" Margin="8,0,0,0"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="AboutPage_SourceLabel" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        <HyperlinkButton x:Uid="AboutPage_SourceLink" Grid.Column="1" NavigateUri="https://github.com/LengxiQwQ/live-photo-studio" Margin="8,0,0,0"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="AboutPage_IssueLabel" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        <HyperlinkButton x:Uid="AboutPage_IssueLink" Grid.Column="1" NavigateUri="https://github.com/LengxiQwQ/live-photo-studio/issues" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>