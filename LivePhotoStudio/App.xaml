<Application
    x:Class="LivePhotoStudio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="CyberCyanBrush" Color="#00E5FF"/>
            <SolidColorBrush x:Key="CyberPurpleBrush" Color="#B388FF"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource SystemAltHighColor}" Opacity="0.6"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>